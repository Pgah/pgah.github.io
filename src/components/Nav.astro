---
const current = Astro.url.pathname;

const links = [
  { href: '/',       label: 'blogs',  match: '/' },
  { href: '/about',  label: 'about',   match: '/about' },
  { href: '/rss.xml',label: 'follow-the-white-rabbit', match: null, external: true },
];
---

<nav>
  <div class="palette-search">
    <span class="palette-caret">&gt;</span>
    <span class="palette-text">Mr.Anderson@pgah</span>
    <span class="cursor">&#x2588;</span>
  </div>
  <div class="palette-divider"></div>
  <div class="palette-tabs">
    {links.map(link => (
      <a
        href={link.href}
        class={`palette-tab ${link.match && current === link.match ? 'active' : ''}`}
        target={link.external ? '_blank' : undefined}
      >
        {link.label}
      </a>
    ))}
  </div>
</nav>

<style>
nav {
  margin-bottom: 2.5rem;
  border: 1px solid var(--fg-muted);
  font-size: 0.9rem;
}

.palette-search {
  display: flex;
  align-items: center;
  gap: 0.5ch;
  padding: 0.5rem 1rem;
  background: var(--bg-soft);
}

.palette-caret {
  color: var(--fg-bright);
}

.palette-text {
  color: var(--fg);
  flex: 1;
}

.palette-divider {
  height: 1px;
  background: var(--fg-muted);
}

.palette-tabs {
  display: flex;
}

.palette-tab {
  flex: 1;
  text-align: center;
  padding: 0.4rem 0;
  color: var(--fg-dim);
  border-right: 1px solid var(--fg-muted);
  transition: background 0.1s, color 0.1s;
}

.palette-tab:last-child {
  border-right: none;
}

.palette-tab:hover {
  background: var(--bg-soft);
  color: var(--fg-bright);
  text-decoration: none;
}

.palette-tab.active {
  color: var(--fg-bright);
  background: var(--bg-soft);
  border-bottom: 2px solid var(--fg);
}
</style>
