---

<canvas id="matrix-canvas"></canvas>

<script>
const canvas = document.getElementById('matrix-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;

// Karakterler Linux/siber komutlardan çıkarıldı
const chars = 'abcdefghijklmnopqrstuvwxyz0123456789/\\-_.@$#!|&><=+*%[]{}();:'.split('');

const fontSize = 14;
let drops: number[] = [];

function resize() {
  canvas.width  = window.innerWidth;
  canvas.height = window.innerHeight;
  const colCount = Math.floor(canvas.width / fontSize);
  drops = Array.from({ length: colCount }, () => Math.random() * (canvas.height / fontSize));
}

resize();
window.addEventListener('resize', resize);

function draw() {
  ctx.fillStyle = 'rgba(14, 9, 0, 0.05)';
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  ctx.font = `${fontSize}px 'Courier New', monospace`;

  for (let i = 0; i < drops.length; i++) {
    const char = chars[Math.floor(Math.random() * chars.length)];
    const x = i * fontSize;
    const y = drops[i] * fontSize;

    // Baş karakter: beyazımsı
    ctx.fillStyle = '#fff8e0';
    ctx.fillText(char, x, y);

    // Bir önceki satır: parlak amber
    ctx.fillStyle = '#ffd060';
    ctx.fillText(chars[Math.floor(Math.random() * chars.length)], x, y - fontSize);

    // Geri kalanlar soluklaşıyor
    ctx.fillStyle = '#ffb000';
    ctx.fillText(chars[Math.floor(Math.random() * chars.length)], x, y - fontSize * 2);

    ctx.fillStyle = '#a07000';
    ctx.fillText(chars[Math.floor(Math.random() * chars.length)], x, y - fontSize * 3);

    if (y > canvas.height && Math.random() > 0.975) {
      drops[i] = 0;
    }
    drops[i] += 0.6;
  }
}

setInterval(draw, 40);
</script>

<style>
#matrix-canvas {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
  pointer-events: none;
  opacity: 0.5;
}
</style>
