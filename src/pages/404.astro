---
import BaseLayout from '../layouts/BaseLayout.astro';
import Prompt from '../components/Prompt.astro';
---

<script>
  if (window.location.pathname === '/rss.xml') {
    window.location.replace('https://www.youtube.com/watch?v=ztABYog5x3o');
  }
</script>

<BaseLayout title="404" description="Page not found">
  <Prompt path="???" command="cd /this/path" />

  <div class="error-block">
    <p class="error-code">bash: cd: /this/path: No such file or directory</p>
    <p class="error-hint">Exit code: <span class="highlight">404</span></p>
  </div>

  <div class="suggestion">
    <p class="dim">Try one of these instead:</p>
    <div class="links">
      <a href="/">~/blogs</a>
      <a href="/about">~/about</a>
    </div>
  </div>
</BaseLayout>

<style>
.error-block {
  margin-bottom: 2rem;
}
.error-code {
  color: var(--red);
  margin-bottom: 0.5rem;
}
.error-hint {
  color: var(--fg-dim);
}
.highlight {
  color: var(--fg-bright);
}
.suggestion {
  margin-top: 1.5rem;
}
.dim {
  color: var(--fg-muted);
  margin-bottom: 0.5rem;
}
.links {
  display: flex;
  gap: 2ch;
  padding-left: 2ch;
}
.links a {
  color: var(--fg-bright);
}
</style>
