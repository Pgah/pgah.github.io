---
import MatrixRain from '../components/MatrixRain.astro';
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>404 — /dev/pgah</title>
  <script src="/404-redirect.js"></script>
</head>
<body>
  <MatrixRain />

  <div class="center">
    <p class="wake">WAKE UP, NEO...</p>
    <p class="sub">This page does not exist.</p>
    <a href="/" class="back">// return to reality</a>
  </div>
</body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    background: #000;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Courier New', monospace;
  }

  .center {
    position: relative;
    z-index: 10;
    text-align: center;
  }

  .wake {
    font-size: 3rem;
    color: #fff8e0;
    letter-spacing: 0.2em;
    margin-bottom: 1rem;
    text-shadow: 0 0 20px #f5e840, 0 0 40px #e8d000;
  }

  .sub {
    font-size: 1rem;
    color: #a09000;
    letter-spacing: 0.1em;
    margin-bottom: 2rem;
  }

  .back {
    font-size: 0.9rem;
    color: #f5e840;
    text-decoration: none;
    letter-spacing: 0.1em;
    border: 1px solid #a09000;
    padding: 0.5rem 1.5rem;
    transition: all 0.2s;
  }

  .back:hover {
    background: #f5e840;
    color: #000;
  }
</style>
