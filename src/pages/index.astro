---
import BaseLayout from '../layouts/BaseLayout.astro';
import Prompt from '../components/Prompt.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const postsJson = JSON.stringify(posts.map(p => {
  const d = p.data.date;
  return {
    id: p.id,
    date: p.data.date.valueOf(),
    dateStr: `${String(d.getUTCDate()).padStart(2,'0')}/${String(d.getUTCMonth()+1).padStart(2,'0')}/${d.getUTCFullYear()}`,
  };
}));
---

<BaseLayout title="blogs">
  <Prompt command="ls -la ~/blogs" />

  <div class="listing">
    <div class="listing-header">
      <span class="col-perm">permissions</span>
      <span class="col-date sort-btn" id="sort-date">date <span class="sort-arrow">↓</span></span>
      <span class="col-name sort-btn" id="sort-name">name <span class="sort-arrow"></span></span>
    </div>

    <div id="listing-body">
      {posts.map((post) => {
        const d = post.data.date;
        const dateStr = `${String(d.getUTCDate()).padStart(2,'0')}/${String(d.getUTCMonth()+1).padStart(2,'0')}/${d.getUTCFullYear()}`;
        return (
          <div class="listing-row">
            <span class="col-perm perm">-rw-r--r--</span>
            <span class="col-date date">{dateStr}</span>
            <a class="col-name" href={`/posts/${post.id}`}>{post.data.title}</a>
          </div>
        );
      })}
    </div>

    {posts.length === 0 && (
      <div class="listing-row empty-row">
        <span class="col-perm perm">──────────</span>
        <span class="col-date date">──────────</span>
        <span class="col-name muted">──────────</span>
      </div>
    )}
  </div>

  <script type="application/json" id="posts-data" set:html={postsJson}></script>

  <div id="terminal-output"></div>

  <div class="cursor-line" id="cursor-line">
    <span class="prompt-dim">sleeper@matrix:~/blogs$</span>&nbsp;<input class="terminal-input" id="terminal-input" type="text" autocomplete="off" spellcheck="false" />
  </div>
</BaseLayout>

<script>
  const posts = JSON.parse(document.getElementById('posts-data').textContent);
  let sortKey = 'date';
  let sortDir = -1;

  const body = document.getElementById('listing-body');
  const btnDate = document.getElementById('sort-date');
  const btnName = document.getElementById('sort-name');

  const rows = Array.from(body.querySelectorAll('.listing-row'));
  rows.forEach((row, i) => {
    row.dataset.date = posts[i].date;
    row.dataset.id = posts[i].id;
  });

  function thirdWord(id) {
    return id.split('-').slice(2).join('-');
  }

  function render() {
    const sorted = [...rows].sort((a, b) => {
      if (sortKey === 'date') return (Number(a.dataset.date) - Number(b.dataset.date)) * sortDir;
      return thirdWord(a.dataset.id).localeCompare(thirdWord(b.dataset.id)) * sortDir;
    });

    sorted.forEach(row => body.appendChild(row));

    btnDate.querySelector('.sort-arrow').textContent = sortKey === 'date' ? (sortDir === -1 ? '↓' : '↑') : '';
    btnName.querySelector('.sort-arrow').textContent = sortKey === 'name' ? (sortDir === -1 ? '↓' : '↑') : '';
  }

  btnDate.addEventListener('click', () => {
    if (sortKey === 'date') sortDir *= -1;
    else { sortKey = 'date'; sortDir = -1; }
    render();
  });

  btnName.addEventListener('click', () => {
    if (sortKey === 'name') sortDir *= -1;
    else { sortKey = 'name'; sortDir = 1; }
    render();
  });

  const termInput = document.getElementById('terminal-input');
  const termOutput = document.getElementById('terminal-output');
  const cursorLine = document.getElementById('cursor-line');

  cursorLine.addEventListener('click', () => termInput.focus());

  function escapeHtml(str) {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#039;');
  }

  let currentGroup = null;

  function addOutputLine(html) {
    const div = document.createElement('div');
    div.className = 'term-out-line';
    div.innerHTML = html;
    currentGroup.appendChild(div);
  }

  function newGroup() {
    currentGroup = document.createElement('div');
    currentGroup.className = 'term-group';
    termOutput.appendChild(currentGroup);
  }

  let tabCycle = null;

  termInput.addEventListener('keydown', (e) => {
    if (e.key === 'Tab') {
      e.preventDefault();
      const val = termInput.value;
      const m = val.match(/^(cd\s+)(.*)$/);
      if (!m) return;
      const prefix = m[1], partial = m[2];

      if (!tabCycle) {
        const matches = posts.filter(p => p.id.startsWith(partial));
        if (!matches.length) return;
        if (matches.length === 1) {
          termInput.value = prefix + matches[0].id;
          return;
        }
        let common = matches[0].id;
        for (const p of matches) while (!p.id.startsWith(common)) common = common.slice(0, -1);
        if (common !== partial) {
          termInput.value = prefix + common;
          tabCycle = { matches, index: -1 };
        } else {
          tabCycle = { matches, index: 0 };
          termInput.value = prefix + matches[0].id;
        }
      } else {
        tabCycle.index = (tabCycle.index + 1) % tabCycle.matches.length;
        const pfx = termInput.value.match(/^(cd\s+)/);
        if (pfx) termInput.value = pfx[1] + tabCycle.matches[tabCycle.index].id;
      }
      return;
    }

    tabCycle = null;
    if (e.key !== 'Enter') return;
    const cmd = termInput.value.trim();
    termInput.value = '';

    newGroup();
    addOutputLine(`<span class="prompt-dim">sleeper@matrix:~/blogs$</span>&nbsp;<span class="term-cmd">${escapeHtml(cmd)}</span>`);

    if (!cmd) return;

    const parts = cmd.split(/\s+/);

    if (parts[0] === 'cd' && parts[1]) {
      const target = parts[1];
      const post = posts.find(p => p.id === target);
      if (post) {
        window.location.href = `/posts/${post.id}`;
      } else {
        addOutputLine(`<span class="term-err">bash: cd: ${escapeHtml(target)}: No such file or directory</span>`);
      }
    } else if (cmd === 'ls -la' || cmd === 'ls -la ~/blogs') {
      posts.forEach(p => addOutputLine(`<span class="perm">-rw-r--r--</span>&nbsp;&nbsp;<span class="date">${p.dateStr}</span>&nbsp;&nbsp;<span class="term-cmd">${p.id}</span>`));
    } else if (parts[0] === 'ls') {
      posts.forEach(p => addOutputLine(`<span class="term-cmd">${p.id}</span>`));
    } else if (cmd === 'clear') {
      termOutput.innerHTML = '';
    } else {
      addOutputLine(`<span class="term-err">bash: ${escapeHtml(parts[0])}: command not found</span>`);
    }
  });
</script>

<style>
.listing {
  width: 100%;
  margin-bottom: 2rem;
}
.listing-header {
  display: grid;
  grid-template-columns: 16ch 16ch 1fr;
  gap: 0 2ch;
  color: var(--fg-bright);
  font-size: 0.8rem;
  margin-bottom: 0.5rem;
  padding-bottom: 0.25rem;
  border-bottom: 1px solid var(--fg-muted);
}
.listing-header .col-date {
  padding-left: 9ch;
  color: var(--fg-bright);
}
.listing-header .col-name {
  padding-left: 25ch;
}
.sort-btn {
  cursor: pointer;
  user-select: none;
}
.sort-btn:hover {
  color: var(--fg-bright);
}
.listing-row {
  display: grid;
  grid-template-columns: 16ch 16ch 1fr;
  gap: 0 2ch;
  padding: 0.15rem 0;
  align-items: baseline;
}
.perm  { color: var(--fg-bright); }
.muted { color: var(--fg-muted); }
.date  { color: var(--fg-bright); }
.col-name { color: var(--fg-bright); }
.col-desc { color: var(--fg-dim); font-size: 0.9rem; }
.cursor-line {
  margin-top: 1rem;
  display: flex;
  align-items: center;
  gap: 0.5ch;
}
.prompt-dim { color: var(--fg-dim); }
.terminal-input {
  background: transparent;
  border: none;
  outline: none;
  color: var(--fg-bright);
  font-family: 'Courier New', monospace;
  font-size: inherit;
  caret-color: var(--fg-bright);
  flex: 1;
  min-width: 0;
}
.term-group {
  margin-top: 1.5rem;
}
.term-out-line {
  margin-top: 0.25rem;
  font-size: inherit;
}
.term-cmd { color: var(--fg-bright); }
.term-err { color: #e05252; }

@media (max-width: 600px) {
  .listing-header { display: none; }
  .listing-row {
    grid-template-columns: 1fr;
    gap: 0;
    margin-bottom: 1rem;
  }
  .perm { display: none; }
}
</style>
