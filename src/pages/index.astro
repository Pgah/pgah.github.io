---
import BaseLayout from '../layouts/BaseLayout.astro';
import Prompt from '../components/Prompt.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const postsJson = JSON.stringify(posts.map(p => {
  const d = p.data.date;
  return {
    id: p.id,
    date: p.data.date.valueOf(),
    dateStr: `${String(d.getUTCDate()).padStart(2,'0')}/${String(d.getUTCMonth()+1).padStart(2,'0')}/${d.getUTCFullYear()}`,
  };
}));
---

<BaseLayout title="blogs">
  <Prompt command="ls -la ~/blogs" />

  <div class="listing">
    <div class="listing-header">
      <span class="col-perm">permissions</span>
      <span class="col-date sort-btn" id="sort-date">date <span class="sort-arrow">↓</span></span>
      <span class="col-name sort-btn" id="sort-name">name <span class="sort-arrow"></span></span>
    </div>

    <div id="listing-body">
      {posts.map((post) => {
        const d = post.data.date;
        const dateStr = `${String(d.getUTCDate()).padStart(2,'0')}/${String(d.getUTCMonth()+1).padStart(2,'0')}/${d.getUTCFullYear()}`;
        return (
          <div class="listing-row">
            <span class="col-perm perm">-rw-r--r--</span>
            <span class="col-date date">{dateStr}</span>
            <a class="col-name" href={`/posts/${post.id}`}>{post.data.title}</a>
          </div>
        );
      })}
    </div>

    {posts.length === 0 && (
      <div class="listing-row empty-row">
        <span class="col-perm perm">──────────</span>
        <span class="col-date date">──────────</span>
        <span class="col-name muted">──────────</span>
      </div>
    )}
  </div>

  <div class="cursor-line">
    <span class="prompt-dim">sleeper@matrix:~/posts$</span> <span class="cursor">&#x2588;</span>
  </div>
</BaseLayout>

<script define:vars={{ postsJson }}>
  const posts = JSON.parse(postsJson);
  let sortKey = 'date';
  let sortDir = -1;

  const body = document.getElementById('listing-body');
  const btnDate = document.getElementById('sort-date');
  const btnName = document.getElementById('sort-name');

  const rows = Array.from(body.querySelectorAll('.listing-row'));
  rows.forEach((row, i) => {
    row.dataset.date = posts[i].date;
    row.dataset.id = posts[i].id;
  });

  function thirdWord(id) {
    return id.split('-').slice(2).join('-');
  }

  function render() {
    const sorted = [...rows].sort((a, b) => {
      if (sortKey === 'date') return (Number(a.dataset.date) - Number(b.dataset.date)) * sortDir;
      return thirdWord(a.dataset.id).localeCompare(thirdWord(b.dataset.id)) * sortDir;
    });

    sorted.forEach(row => body.appendChild(row));

    btnDate.querySelector('.sort-arrow').textContent = sortKey === 'date' ? (sortDir === -1 ? '↓' : '↑') : '';
    btnName.querySelector('.sort-arrow').textContent = sortKey === 'name' ? (sortDir === -1 ? '↓' : '↑') : '';
  }

  btnDate.addEventListener('click', () => {
    if (sortKey === 'date') sortDir *= -1;
    else { sortKey = 'date'; sortDir = -1; }
    render();
  });

  btnName.addEventListener('click', () => {
    if (sortKey === 'name') sortDir *= -1;
    else { sortKey = 'name'; sortDir = 1; }
    render();
  });
</script>

<style>
.listing {
  width: 100%;
  margin-bottom: 2rem;
}
.listing-header {
  display: grid;
  grid-template-columns: 16ch 16ch 1fr;
  gap: 0 2ch;
  color: var(--fg-muted);
  font-size: 0.8rem;
  margin-bottom: 0.5rem;
  padding-bottom: 0.25rem;
  border-bottom: 1px solid var(--fg-muted);
}
.listing-header .col-date {
  padding-left: 9ch;
}
.listing-header .col-name {
  padding-left: 15ch;
}
.sort-btn {
  cursor: pointer;
  user-select: none;
}
.sort-btn:hover {
  color: var(--fg-bright);
}
.listing-row {
  display: grid;
  grid-template-columns: 16ch 16ch 1fr;
  gap: 0 2ch;
  padding: 0.15rem 0;
  align-items: baseline;
}
.perm  { color: var(--fg-muted); }
.muted { color: var(--fg-muted); }
.date  { color: var(--fg-dim); }
.col-name { color: var(--fg-bright); }
.col-desc { color: var(--fg-dim); font-size: 0.9rem; }
.cursor-line {
  margin-top: 1rem;
  display: flex;
  align-items: center;
  gap: 0.5ch;
}
.prompt-dim { color: var(--fg-dim); }

@media (max-width: 600px) {
  .listing-header { display: none; }
  .listing-row {
    grid-template-columns: 1fr;
    gap: 0;
    margin-bottom: 1rem;
  }
  .perm { display: none; }
}
</style>
