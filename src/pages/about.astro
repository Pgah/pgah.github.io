---
import BaseLayout from '../layouts/BaseLayout.astro';
import Prompt from '../components/Prompt.astro';
---

<BaseLayout title="about" description="about Mr.Anderson">
  <Prompt command="man about" />

  <div class="manpage">
    <section>
      <h2>NAME</h2>
      <p class="indent">Mr.Anderson </p>
    </section>

    <section>
      <h2>CHOICE</h2>
      <p class="indent">[--red-pill] [--blue-pill]</p>
    </section>

    <section>
      <h2>PORPUSE</h2>
      <p class="indent">
        You take the blue pill, the story ends. You take the red pill, you stay in Wonderland and I show you how deep the rabbit hole goes.
      </p>
    </section>

    <section>
      <h2>CONTACT</h2>
      <div class="options">
        <div class="option-row">
          <span class="flag">--github</span>
          <a href="https://github.com/Pgah" target="_blank">github.com/Pgah</a>
        </div>
        <div class="option-row">
          <span class="flag">--blog</span>
          <a href="/">pgah.github.io</a>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
.manpage section {
  margin-bottom: 1.5rem;
}
.manpage h2 {
  color: var(--fg-bright);
  font-size: 1rem;
  margin: 0 0 0.4rem;
  letter-spacing: 0.05em;
}
.indent {
  padding-left: 4ch;
}
.cmd {
  color: var(--fg-bright);
}
.options {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  padding-left: 4ch;
}
.option-row {
  display: grid;
  grid-template-columns: 16ch 1fr;
  gap: 0 2ch;
}
.flag {
  color: var(--fg-dim);
}
</style>
